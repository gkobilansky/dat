# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://dat:dat@localhost:5432/dat

# Redis: BullMQ queues + progress pub/sub
REDIS_URL=redis://localhost:6379

# MinIO: repo bundles + large binary originals
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=dat
S3_SECRET_KEY=dat-secret
S3_BUCKET_BUNDLES=dat-bundles
S3_BUCKET_ORIGINALS=dat-originals

# Local volume holding one bare repo + worktree per case
CASE_STORAGE_DIR=./data/cases

# Anthropic (worker / agent)
ANTHROPIC_API_KEY=

# Auth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000
